---
export const prerender = false;

import BlogLayout from "../../layouts/BlogLayout.astro";
import TOC from "../../components/blog/TOC.astro";
import CommentForm from "../../components/vue/CommentForm.vue";
import { t, initLocale } from "../../i18n/index";

initLocale(Astro.request);

const { slug } = Astro.params;
const API_BASE = import.meta.env.PUBLIC_API_URL || "http://localhost:3000";

let post: any = null;

try {
  const res = await fetch(`${API_BASE}/api/v1/posts/${slug}`);
  const json = await res.json();
  if (json.success) post = json.data;
} catch {
  // API not available
}

if (!post) {
  return Astro.redirect("/404");
}

const date = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString("zh-CN", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "";

const plainText = (post.content || "").replace(/[#*`~>\[\]()!_\-|]/g, "");
const wordCount = plainText.length;
const readingTime = Math.max(1, Math.ceil(wordCount / 400));

// Extract headings from HTML for TOC
const headingRegex = /<h([2-3])\s+id="([^"]*)"[^>]*>([^<]*)<\/h[2-3]>/g;
const headings: { depth: number; slug: string; text: string }[] = [];
let match;
while ((match = headingRegex.exec(post.contentHtml)) !== null) {
  headings.push({ depth: Number(match[1]), slug: match[2], text: match[3] });
}
---

<BlogLayout
  title={`${post.title} - ${t("site.name")}`}
  description={post.excerpt}
  ogImage={post.coverImage}
  ogType="article"
>
  <!-- Reading progress bar -->
  <div class="reading-progress" id="reading-progress"></div>

  {post.series && (
    <nav class="series-nav">
      <div class="series-header">
        <span class="series-label">{t("post.series")}</span>
        <strong>{post.series.name}</strong>
      </div>
      <ol class="series-list">
        {post.series.posts.map((p: any) => (
          <li class:list={[{ current: p.id === post.id }]}>
            {p.id === post.id ? <span>{p.title}</span> : <a href={`/post/${p.slug}`}>{p.title}</a>}
          </li>
        ))}
      </ol>
    </nav>
  )}

  <div class="post-page">
    <article class="post-content">
      <header class="post-header">
        {post.category && (
          <a href={`/category/${post.category.slug}`} class="post-category">
            {post.category.name}
          </a>
        )}
        <h1>{post.title}</h1>
        <div class="post-meta">
          {post.author && <span>{post.author.displayName}</span>}
          {date && <time>{date}</time>}
          <span>{t("post.minRead", { n: readingTime })}</span>
          <span>{t("post.views", { n: post.viewCount || 0 })}</span>
          <span class="like-count" id="like-count">{post.likeCount || 0}</span>
        </div>
        {post.tags?.length > 0 && (
          <div class="post-tags">
            {post.tags.map((tag: any) => (
              <a href={`/tag/${tag.slug}`} class="tag">{tag.name}</a>
            ))}
          </div>
        )}
      </header>
      {post.coverImage && (
        <img src={post.coverImage} alt={post.title} class="cover-image" loading="lazy" />
      )}
      <div class="prose" set:html={post.contentHtml} />
    </article>
    {headings.length > 0 && (
      <aside class="post-sidebar">
        <TOC headings={headings} />
      </aside>
    )}
  </div>
  {(post.prevPost || post.nextPost) && (
    <nav class="post-nav">
      <div class="post-nav-item prev">
        {post.prevPost && (
          <>
            <span class="post-nav-label">{t("post.previous")}</span>
            <a href={`/post/${post.prevPost.slug}`}>{post.prevPost.title}</a>
          </>
        )}
      </div>
      <div class="post-nav-item next">
        {post.nextPost && (
          <>
            <span class="post-nav-label">{t("post.next")}</span>
            <a href={`/post/${post.nextPost.slug}`}>{post.nextPost.title}</a>
          </>
        )}
      </div>
    </nav>
  )}
  <div class="share-bar">
    <span class="share-label">{t("post.share")}</span>
    <a class="share-btn twitter" href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener" title="Twitter">𝕏</a>
    <a class="share-btn facebook" href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`} target="_blank" rel="noopener" title="Facebook">f</a>
    <button class="share-btn copy-link" id="copy-link-btn" title={t("post.copyLink")}>🔗</button>
  </div>
  {post.relatedPosts?.length > 0 && (
    <section class="related-section">
      <h2>{t("post.relatedPosts")}</h2>
      <div class="related-grid">
        {post.relatedPosts.map((rp: any) => (
          <a href={`/post/${rp.slug}`} class="related-card">
            {rp.coverImage && <img src={rp.coverImage} alt={rp.title} loading="lazy" />}
            <div class="related-info">
              <h3>{rp.title}</h3>
              {rp.excerpt && <p>{rp.excerpt}</p>}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}
  <section class="comments-section">
    <h2>{t("post.comments")}</h2>
    <CommentForm client:visible slug={slug!} />
  </section>
  {post.author?.bio && (
    <section class="author-card">
      <div class="author-avatar">
        {post.author.avatar ? <img src={post.author.avatar} alt={post.author.displayName} /> : <div class="avatar-placeholder">{post.author.displayName[0]}</div>}
      </div>
      <div class="author-info">
        <h3>{post.author.displayName}</h3>
        <p>{post.author.bio}</p>
        {post.author.website && <a href={post.author.website} target="_blank" rel="noopener">{post.author.website}</a>}
      </div>
    </section>
  )}
  <button class="like-btn" id="like-btn" aria-label="Like">♡ <span id="like-text">{post.likeCount || 0}</span></button>

  {post.author && post.author.bio && (
    <section class="author-card">
      <div class="author-avatar">
        {post.author.avatar
          ? <img src={post.author.avatar} alt={post.author.displayName} />
          : <div class="avatar-placeholder">{post.author.displayName.charAt(0)}</div>}
      </div>
      <div class="author-info">
        <h3>{post.author.displayName}</h3>
        <p>{post.author.bio}</p>
        {post.author.website && <a href={post.author.website} target="_blank" rel="noopener">{post.author.website}</a>}
      </div>
    </section>
  )}

  <div class="shortcuts-overlay" id="shortcuts-overlay" style="display:none">
    <div class="shortcuts-card">
      <h3>{t("post.shortcuts")}</h3>
      <ul>
        <li><kbd>&larr;</kbd> / <kbd>j</kbd> {t("post.previous")}</li>
        <li><kbd>&rarr;</kbd> / <kbd>k</kbd> {t("post.next")}</li>
        <li><kbd>l</kbd> {t("post.like")}</li>
        <li><kbd>?</kbd> {t("post.toggleShortcuts")}</li>
        <li><kbd>Esc</kbd> {t("post.closeOverlay")}</li>
      </ul>
      <button class="btn" id="close-shortcuts-btn">{t("admin.cancelBtn")}</button>
    </div>
  </div>
</BlogLayout>

<script>
  document.querySelectorAll(".prose .shiki").forEach(function(block) {
    const btn = document.createElement("button");
    btn.className = "code-copy-btn";
    btn.textContent = "Copy";
    btn.addEventListener("click", function() {
      const code = block.querySelector("code");
      if (!code) return;
      navigator.clipboard.writeText(code.textContent || "").then(function() {
        btn.textContent = "Copied!";
        btn.classList.add("copied");
        setTimeout(function() {
          btn.textContent = "Copy";
          btn.classList.remove("copied");
        }, 2000);
      });
    });
    block.appendChild(btn);
  });

  // Image lightbox
  document.querySelectorAll(".prose img").forEach(function(img) {
    (img as HTMLElement).style.cursor = "zoom-in";
    img.addEventListener("click", function() {
      const overlay = document.createElement("div");
      overlay.className = "lightbox-overlay";
      const clone = img.cloneNode(true) as HTMLElement;
      clone.style.cursor = "zoom-out";
      overlay.appendChild(clone);
      overlay.addEventListener("click", function() { overlay.remove(); });
      document.body.appendChild(overlay);
    });
  });
</script>

<script>
  (function() {
    const bar = document.getElementById("reading-progress");
    if (!bar) return;
    window.addEventListener("scroll", function() {
      const h = document.documentElement.scrollHeight - window.innerHeight;
      const pct = h > 0 ? Math.min(100, (window.scrollY / h) * 100) : 0;
      bar.style.width = pct + "%";
    });
  })();
</script>

<script is:inline>
(function(){var b=document.getElementById("copy-link-btn");if(b)b.addEventListener("click",function(){navigator.clipboard.writeText(window.location.href).then(function(){b.textContent="✓";setTimeout(function(){b.textContent="🔗"},2000)})})})();
</script>

<script is:inline>
(function(){
  var btn=document.getElementById("like-btn");
  var slug=window.location.pathname.split("/post/")[1];
  if(!btn||!slug)return;
  fetch("/api/v1/posts/"+slug+"/likes").then(function(r){return r.json()}).then(function(d){
    if(d.success){
      btn.querySelector("span").textContent=d.data.count;
      if(d.data.liked)btn.classList.add("liked");
    }
  });
  btn.addEventListener("click",function(){
    fetch("/api/v1/posts/"+slug+"/like",{method:"POST"}).then(function(r){return r.json()}).then(function(d){
      if(d.success){
        btn.querySelector("span").textContent=d.data.count;
        btn.classList.toggle("liked",d.data.liked);
      }
    });
  });
})();
</script>

<script is:inline>
(function(){
  document.addEventListener("keydown", function(e) {
    if (e.target.tagName === "INPUT" || e.target.tagName === "TEXTAREA") return;
    if (e.key === "ArrowLeft" || e.key === "j") {
      var prev = document.querySelector(".post-nav-item.prev a");
      if (prev) prev.click();
    }
    if (e.key === "ArrowRight" || e.key === "k") {
      var next = document.querySelector(".post-nav-item.next a");
      if (next) next.click();
    }
    if (e.key === "l") {
      var like = document.getElementById("like-btn");
      if (like) like.click();
    }
    if (e.key === "?" && !e.ctrlKey) {
      var help = document.getElementById("shortcuts-overlay");
      if (help) help.style.display = help.style.display === "flex" ? "none" : "flex";
    }
    if (e.key === "Escape") {
      var overlay = document.getElementById("shortcuts-overlay");
      if (overlay) overlay.style.display = "none";
      var lightbox = document.querySelector(".lightbox-overlay");
      if (lightbox) lightbox.remove();
    }
  });
  var closeBtn = document.getElementById("close-shortcuts-btn");
  if (closeBtn) closeBtn.addEventListener("click", function() {
    document.getElementById("shortcuts-overlay").style.display = "none";
  });
})();
</script>

