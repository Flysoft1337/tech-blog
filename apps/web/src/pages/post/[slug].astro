---
export const prerender = false;

import BlogLayout from "../../layouts/BlogLayout.astro";
import TOC from "../../components/blog/TOC.astro";
import CommentForm from "../../components/vue/CommentForm.vue";
import { t, initLocale } from "../../i18n/index";

initLocale(Astro.request);

const { slug } = Astro.params;
const API_BASE = import.meta.env.PUBLIC_API_URL || "http://localhost:3000";

let post: any = null;

try {
  const res = await fetch(`${API_BASE}/api/v1/posts/${slug}`);
  const json = await res.json();
  if (json.success) post = json.data;
} catch {
  // API not available
}

if (!post) {
  return Astro.redirect("/404");
}

const date = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString("zh-CN", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "";

const plainText = (post.content || "").replace(/[#*`~>\[\]()!_\-|]/g, "");
const wordCount = plainText.length;
const readingTime = Math.max(1, Math.ceil(wordCount / 400));

// Extract headings from HTML for TOC
const headingRegex = /<h([2-3])\s+id="([^"]*)"[^>]*>([^<]*)<\/h[2-3]>/g;
const headings: { depth: number; slug: string; text: string }[] = [];
let match;
while ((match = headingRegex.exec(post.contentHtml)) !== null) {
  headings.push({ depth: Number(match[1]), slug: match[2], text: match[3] });
}
---

<BlogLayout
  title={`${post.title} - ${t("site.name")}`}
  description={post.excerpt}
  ogImage={post.coverImage}
  ogType="article"
>
  <div class="post-page">
    <article class="post-content">
      <header class="post-header">
        {post.category && (
          <a href={`/category/${post.category.slug}`} class="post-category">
            {post.category.name}
          </a>
        )}
        <h1>{post.title}</h1>
        <div class="post-meta">
          {post.author && <span>{post.author.displayName}</span>}
          {date && <time>{date}</time>}
          <span>{t("post.minRead", { n: readingTime })}</span>
        </div>
        {post.tags?.length > 0 && (
          <div class="post-tags">
            {post.tags.map((tag: any) => (
              <a href={`/tag/${tag.slug}`} class="tag">{tag.name}</a>
            ))}
          </div>
        )}
      </header>
      {post.coverImage && (
        <img src={post.coverImage} alt={post.title} class="cover-image" />
      )}
      <div class="prose" set:html={post.contentHtml} />
    </article>
    {headings.length > 0 && (
      <aside class="post-sidebar">
        <TOC headings={headings} />
      </aside>
    )}
  </div>
  {(post.prevPost || post.nextPost) && (
    <nav class="post-nav">
      <div class="post-nav-item prev">
        {post.prevPost && (
          <>
            <span class="post-nav-label">{t("post.previous")}</span>
            <a href={`/post/${post.prevPost.slug}`}>{post.prevPost.title}</a>
          </>
        )}
      </div>
      <div class="post-nav-item next">
        {post.nextPost && (
          <>
            <span class="post-nav-label">{t("post.next")}</span>
            <a href={`/post/${post.nextPost.slug}`}>{post.nextPost.title}</a>
          </>
        )}
      </div>
    </nav>
  )}
  <section class="comments-section">
    <h2>{t("post.comments")}</h2>
    <CommentForm client:visible slug={slug!} />
  </section>
</BlogLayout>

<script>
  document.querySelectorAll(".prose .shiki").forEach(function(block) {
    const btn = document.createElement("button");
    btn.className = "code-copy-btn";
    btn.textContent = "Copy";
    btn.addEventListener("click", function() {
      const code = block.querySelector("code");
      if (!code) return;
      navigator.clipboard.writeText(code.textContent || "").then(function() {
        btn.textContent = "Copied!";
        btn.classList.add("copied");
        setTimeout(function() {
          btn.textContent = "Copy";
          btn.classList.remove("copied");
        }, 2000);
      });
    });
    block.appendChild(btn);
  });
</script>

<style>
  .post-page {
    display: flex;
    gap: 3rem;
  }
  .post-content {
    flex: 1;
    min-width: 0;
  }
  .post-sidebar {
    width: 240px;
    flex-shrink: 0;
  }
  .post-header {
    margin-bottom: 2rem;
  }
  .post-category {
    font-size: 0.85rem;
    color: var(--color-primary);
  }
  .post-header h1 {
    font-size: 2.25rem;
    line-height: 1.3;
    margin: 0.5rem 0;
  }
  .post-meta {
    display: flex;
    gap: 1rem;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }
  .post-tags {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
    flex-wrap: wrap;
  }
  .tag {
    background: var(--color-bg-secondary);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }
  .tag:hover {
    background: var(--color-primary);
    color: white;
  }
  .cover-image {
    width: 100%;
    border-radius: var(--radius);
    margin-bottom: 2rem;
  }
  .comments-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
  .comments-section h2 {
    margin-bottom: 1.5rem;
  }
  .post-nav {
    display: flex;
    gap: 1.5rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }
  .post-nav-item {
    flex: 1;
    min-width: 0;
  }
  .post-nav-item.next {
    text-align: right;
  }
  .post-nav-label {
    display: block;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }
  .post-nav-item a {
    color: var(--color-text);
    font-weight: 500;
    font-size: 0.95rem;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-nav-item a:hover {
    color: var(--color-primary);
  }
  @media (max-width: 1024px) {
    .post-sidebar {
      display: none;
    }
  }
</style>
