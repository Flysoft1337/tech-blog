---
export const prerender = false;

import BlogLayout from "../layouts/BlogLayout.astro";
import { t, initLocale } from "../i18n/index";

initLocale(Astro.request);

const API_BASE = import.meta.env.PUBLIC_API_URL || "http://localhost:3000";

let tags: any[] = [];

try {
  const res = await fetch(`${API_BASE}/api/v1/tags`);
  const json = await res.json();
  if (json.success) tags = json.data.filter((t: any) => t.postCount > 0);
} catch {}

tags.sort((a: any, b: any) => b.postCount - a.postCount);
---

<BlogLayout title={t("tags.title")}>
  <h1 class="page-title">{t("tags.heading")}</h1>
  {tags.length > 0 ? (
    <div class="tags-cloud">
      {tags.map((tag: any) => (
        <a href={`/tag/${tag.slug}`} class="tag-item">
          {tag.name}
          <span class="tag-count">{tag.postCount}</span>
        </a>
      ))}
    </div>
  ) : (
    <p class="empty">{t("tags.empty")}</p>
  )}
</BlogLayout>

<style>
  .page-title {
    font-size: 1.75rem;
    margin-bottom: 1.5rem;
  }
  .tags-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    max-width: var(--content-width);
  }
  .tag-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    color: var(--color-text);
    font-size: 0.9rem;
    transition: all 0.2s;
  }
  .tag-item:hover {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }
  .tag-item:hover .tag-count {
    background: rgba(255, 255, 255, 0.2);
    color: white;
  }
  .tag-count {
    font-size: 0.7rem;
    padding: 0.1rem 0.4rem;
    border-radius: 10px;
    background: var(--color-bg-secondary);
    color: var(--color-text-secondary);
    font-weight: 600;
  }
  .empty {
    color: var(--color-text-secondary);
    text-align: center;
    padding: 3rem 0;
  }
</style>
