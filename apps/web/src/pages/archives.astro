---
export const prerender = false;

import BlogLayout from "../layouts/BlogLayout.astro";
import { t, initLocale } from "../i18n/index";

initLocale(Astro.request);

const API_BASE = import.meta.env.PUBLIC_API_URL || "http://localhost:3000";

let posts: any[] = [];

try {
  let page = 1;
  let hasMore = true;
  while (hasMore) {
    const res = await fetch(`${API_BASE}/api/v1/posts?page=${page}&pageSize=100`);
    const json = await res.json();
    if (json.success && json.data.items.length > 0) {
      posts.push(...json.data.items);
      hasMore = page < json.data.totalPages;
      page++;
    } else {
      hasMore = false;
    }
  }
} catch {}

// Group by year
const grouped: Record<string, any[]> = {};
for (const post of posts) {
  const year = post.publishedAt
    ? new Date(post.publishedAt).getFullYear().toString()
    : t("archives.draft");
  if (!grouped[year]) grouped[year] = [];
  grouped[year].push(post);
}

const years = Object.keys(grouped).sort((a, b) => b.localeCompare(a));
---

<BlogLayout title={t("archives.title")}>
  <h1 class="page-title">{t("archives.heading")}</h1>
  <p class="total-count">{t("archives.totalPosts", { count: posts.length })}</p>
  {years.map((year) => (
    <section class="year-section">
      <h2 class="year-title">{year}</h2>
      <ul class="archive-list">
        {grouped[year].map((post: any) => {
          const date = post.publishedAt
            ? new Date(post.publishedAt).toLocaleDateString("zh-CN", {
                month: "2-digit",
                day: "2-digit",
              })
            : "";
          return (
            <li>
              <time>{date}</time>
              <a href={`/post/${post.slug}`}>{post.title}</a>
            </li>
          );
        })}
      </ul>
    </section>
  ))}
</BlogLayout>

<style>
  .page-title {
    font-size: 1.75rem;
    margin-bottom: 0.25rem;
  }
  .total-count {
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
    font-size: 0.9rem;
  }
  .year-title {
    font-size: 1.25rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--color-border);
  }
  .year-section {
    margin-bottom: 2rem;
  }
  .archive-list {
    list-style: none;
    padding: 0;
  }
  .archive-list li {
    display: flex;
    gap: 1rem;
    padding: 0.375rem 0;
  }
  .archive-list time {
    color: var(--color-text-secondary);
    font-size: 0.85rem;
    min-width: 50px;
    font-family: monospace;
  }
  .archive-list a {
    color: var(--color-text);
  }
  .archive-list a:hover {
    color: var(--color-primary);
  }
</style>
