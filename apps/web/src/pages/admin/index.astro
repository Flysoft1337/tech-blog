---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { t, initLocale } from "../../i18n/index";

initLocale(Astro.request);
---

<AdminLayout title={t("admin.dashboard")}>
  <div class="admin-header">
    <h1>{t("admin.dashboard")}</h1>
    <a href="/admin/posts/new" class="btn btn-primary">{t("admin.newPost")}</a>
  </div>
  <div id="pending-alert" style="display:none" class="admin-card" >
    <div style="display:flex; align-items:center; justify-content:space-between">
      <span id="pending-text" style="color:#92400e; font-weight:500" data-template={t("admin.pendingModeration", { count: "{count}" })}>
      </span>
      <a href="/admin/comments" class="btn" style="font-size:0.8rem; padding:0.3rem 0.75rem">{t("admin.review")}</a>
    </div>
  </div>
  <div class="stats-grid" id="stats">
    <div class="stat-card">
      <div class="label">{t("admin.published")}</div>
      <div class="value" id="stat-published">-</div>
    </div>
    <div class="stat-card">
      <div class="label">{t("admin.drafts")}</div>
      <div class="value" id="stat-drafts">-</div>
    </div>
    <div class="stat-card">
      <div class="label">{t("admin.comments")}</div>
      <div class="value" id="stat-comments">-</div>
    </div>
    <div class="stat-card">
      <div class="label">{t("admin.categories")}</div>
      <div class="value" id="stat-categories">-</div>
    </div>
  </div>
  <div class="admin-card">
    <h3>{t("admin.recentPosts")}</h3>
    <table class="admin-table" style="margin-top:1rem">
      <thead>
        <tr>
          <th>{t("admin.title")}</th>
          <th>{t("admin.status")}</th>
          <th>{t("admin.date")}</th>
        </tr>
      </thead>
      <tbody id="recent-posts" data-no-posts={t("admin.noPosts")}>
        <tr><td colspan="3" style="text-align:center;">{t("admin.loading")}</td></tr>
      </tbody>
    </table>
  </div>
</AdminLayout>

<style>
  #pending-alert {
    background: #fffbeb;
    border: 1px solid #fbbf24;
    margin-bottom: 1rem;
  }
  :global([data-theme="dark"]) #pending-alert {
    background: #422006;
    border-color: #92400e;
  }
  :global([data-theme="dark"]) #pending-alert span {
    color: #fbbf24 !important;
  }
</style>

<script>
  async function loadDashboard() {
    const token = localStorage.getItem("accessToken");
    const headers = { Authorization: `Bearer ${token}` };

    try {
      const [postsRes, draftsRes, commentsRes, catsRes, pendingRes] = await Promise.all([
        fetch("/api/v1/admin/posts?status=published&pageSize=1", { headers }),
        fetch("/api/v1/admin/posts?status=draft&pageSize=5", { headers }),
        fetch("/api/v1/admin/comments?pageSize=1", { headers }),
        fetch("/api/v1/admin/categories", { headers }),
        fetch("/api/v1/admin/comments?status=pending&pageSize=1", { headers }),
      ]);

      const posts = await postsRes.json();
      const drafts = await draftsRes.json();
      const comments = await commentsRes.json();
      const cats = await catsRes.json();
      const pending = await pendingRes.json();

      document.getElementById("stat-published")!.textContent =
        posts.data?.total?.toString() || "0";
      document.getElementById("stat-drafts")!.textContent =
        drafts.data?.total?.toString() || "0";
      document.getElementById("stat-comments")!.textContent =
        comments.data?.total?.toString() || "0";
      document.getElementById("stat-categories")!.textContent =
        cats.data?.length?.toString() || "0";

      const pendingCount = pending.data?.total || 0;
      if (pendingCount > 0) {
        const alert = document.getElementById("pending-alert")!;
        alert.style.display = "block";
        const pendingText = document.getElementById("pending-text")!;
        const template = pendingText.dataset.template || "{count} comments pending moderation";
        pendingText.textContent = template.replace("{count}", pendingCount.toString());
      }

      const tbody = document.getElementById("recent-posts")!;
      const recentItems = drafts.data?.items || [];
      const publishedRes2 = await fetch("/api/v1/admin/posts?pageSize=5", { headers });
      const allPosts = await publishedRes2.json();
      const items = allPosts.data?.items || [];
      if (items.length) {
        tbody.innerHTML = items
          .map(
            (p: any) => `
          <tr>
            <td><a href="/admin/posts/${p.id}">${p.title}</a></td>
            <td><span class="badge badge-${p.status}">${p.status}</span></td>
            <td>${new Date(p.createdAt).toLocaleDateString("zh-CN")}</td>
          </tr>`
          )
          .join("");
      } else {
        const noPostsText = tbody.dataset.noPosts || "No posts";
        tbody.innerHTML =
          `<tr><td colspan="3" style="text-align:center;">${noPostsText}</td></tr>`;
      }
    } catch {
      // handle error silently
    }
  }

  loadDashboard();
</script>
