---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Dashboard">
  <div class="admin-header">
    <h1>Dashboard</h1>
  </div>
  <div id="pending-alert" style="display:none" class="admin-card" >
    <div style="display:flex; align-items:center; justify-content:space-between">
      <span style="color:#92400e; font-weight:500">
        <span id="pending-count">0</span> comments pending moderation
      </span>
      <a href="/admin/comments" class="btn" style="font-size:0.8rem; padding:0.3rem 0.75rem">Review</a>
    </div>
  </div>
  <div class="stats-grid" id="stats">
    <div class="stat-card">
      <div class="label">Posts</div>
      <div class="value" id="stat-posts">-</div>
    </div>
    <div class="stat-card">
      <div class="label">Comments</div>
      <div class="value" id="stat-comments">-</div>
    </div>
    <div class="stat-card">
      <div class="label">Categories</div>
      <div class="value" id="stat-categories">-</div>
    </div>
    <div class="stat-card">
      <div class="label">Media</div>
      <div class="value" id="stat-media">-</div>
    </div>
  </div>
  <div class="admin-card">
    <h3>Recent Posts</h3>
    <table class="admin-table" style="margin-top:1rem">
      <thead>
        <tr>
          <th>Title</th>
          <th>Status</th>
          <th>Date</th>
        </tr>
      </thead>
      <tbody id="recent-posts">
        <tr><td colspan="3" style="text-align:center;">Loading...</td></tr>
      </tbody>
    </table>
  </div>
</AdminLayout>

<style>
  #pending-alert {
    background: #fffbeb;
    border: 1px solid #fbbf24;
    margin-bottom: 1rem;
  }
</style>

<script>
  async function loadDashboard() {
    const token = localStorage.getItem("accessToken");
    const headers = { Authorization: `Bearer ${token}` };

    try {
      const [postsRes, commentsRes, catsRes, mediaRes, pendingRes] = await Promise.all([
        fetch("/api/v1/admin/posts?pageSize=5", { headers }),
        fetch("/api/v1/admin/comments?pageSize=1", { headers }),
        fetch("/api/v1/admin/categories", { headers }),
        fetch("/api/v1/admin/media?pageSize=1", { headers }),
        fetch("/api/v1/admin/comments?status=pending&pageSize=1", { headers }),
      ]);

      const posts = await postsRes.json();
      const comments = await commentsRes.json();
      const cats = await catsRes.json();
      const media = await mediaRes.json();
      const pending = await pendingRes.json();

      document.getElementById("stat-posts")!.textContent =
        posts.data?.total?.toString() || "0";
      document.getElementById("stat-comments")!.textContent =
        comments.data?.total?.toString() || "0";
      document.getElementById("stat-categories")!.textContent =
        cats.data?.length?.toString() || "0";
      document.getElementById("stat-media")!.textContent =
        media.data?.total?.toString() || "0";

      const pendingCount = pending.data?.total || 0;
      if (pendingCount > 0) {
        const alert = document.getElementById("pending-alert")!;
        alert.style.display = "block";
        document.getElementById("pending-count")!.textContent = pendingCount.toString();
      }

      const tbody = document.getElementById("recent-posts")!;
      if (posts.data?.items?.length) {
        tbody.innerHTML = posts.data.items
          .map(
            (p: any) => `
          <tr>
            <td><a href="/admin/posts/${p.id}">${p.title}</a></td>
            <td><span class="badge badge-${p.status}">${p.status}</span></td>
            <td>${new Date(p.createdAt).toLocaleDateString("zh-CN")}</td>
          </tr>`
          )
          .join("");
      } else {
        tbody.innerHTML =
          '<tr><td colspan="3" style="text-align:center;">No posts</td></tr>';
      }
    } catch {
      // handle error silently
    }
  }

  loadDashboard();
</script>
