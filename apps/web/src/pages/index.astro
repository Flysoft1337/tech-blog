---
export const prerender = false;

import BlogLayout from "../layouts/BlogLayout.astro";
import PostCard from "../components/blog/PostCard.astro";
import Pagination from "../components/common/Pagination.astro";
import { t, initLocale } from "../i18n/index";

initLocale(Astro.request);

const page = Number(Astro.url.searchParams.get("page")) || 1;
const q = Astro.url.searchParams.get("q") || "";
const API_BASE = import.meta.env.PUBLIC_API_URL || "http://localhost:3000";

let posts = { items: [], total: 0, page: 1, pageSize: 10, totalPages: 1 };

try {
  const params = new URLSearchParams({ page: String(page) });
  if (q) params.set("q", q);
  const res = await fetch(`${API_BASE}/api/v1/posts?${params}`);
  const json = await res.json();
  if (json.success) posts = json.data;
} catch {
  // API not available during build
}

const pageTitle = q ? `${t("home.searchResults", { q })} - ${t("site.name")}` : t("home.title");
const basePath = q ? `/?q=${encodeURIComponent(q)}` : "/";
---

<BlogLayout title={pageTitle}>
  <div class="home-content">
    {q && (
      <div class="search-header">
        <h1>{t("home.searchResults", { q })}</h1>
        <p>{t("home.postsFound", { count: posts.total })} <a href="/">{t("home.clearSearch")}</a></p>
      </div>
    )}
    <section class="posts-list">
      {posts.items.length > 0 ? (
        posts.items.map((post: any) => (
          <PostCard
            title={post.title}
            slug={post.slug}
            excerpt={post.excerpt}
            coverImage={post.coverImage}
            publishedAt={post.publishedAt}
            authorName={post.authorName}
            categoryName={post.categoryName}
            categorySlug={post.categorySlug}
            pinned={post.pinned}
          />
        ))
      ) : (
        <div class="empty-state">
          {q ? (
            <>
              <h2>{t("home.noResults")}</h2>
              <p>{t("home.tryDifferent")} <a href="/">{t("home.browseAll")}</a>.</p>
            </>
          ) : (
            <>
              <h2>{t("home.welcome")}</h2>
              <p>{t("home.noPosts")} <a href="/admin">{t("home.adminPanel")}</a>{t("home.startWriting")}</p>
            </>
          )}
        </div>
      )}
    </section>
    <Pagination currentPage={posts.page} totalPages={posts.totalPages} basePath={basePath} />
  </div>
</BlogLayout>

<style>
  .home-content {
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, 2vw, 2rem);
  }
  .search-header {
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }
  .search-header h1 {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }
  .search-header p {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }
  .empty-state {
    text-align: center;
    padding: 6rem 0;
    color: var(--color-text-secondary);
  }
  .empty-state h2 {
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
</style>
