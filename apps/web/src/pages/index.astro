---
export const prerender = false;

import BlogLayout from "../layouts/BlogLayout.astro";
import PostCard from "../components/blog/PostCard.astro";
import Pagination from "../components/common/Pagination.astro";
import { t, initLocale } from "../i18n/index";

initLocale(Astro.request);

const page = Number(Astro.url.searchParams.get("page")) || 1;
const q = Astro.url.searchParams.get("q") || "";
const API_BASE = import.meta.env.PUBLIC_API_URL || "http://localhost:3000";

let posts = { items: [], total: 0, page: 1, pageSize: 10, totalPages: 1 };
let popularPosts: any[] = [];

try {
  const params = new URLSearchParams({ page: String(page) });
  if (q) params.set("q", q);
  const [postsRes, popularRes] = await Promise.all([
    fetch(`${API_BASE}/api/v1/posts?${params}`),
    fetch(`${API_BASE}/api/v1/posts/popular`),
  ]);
  const json = await postsRes.json();
  if (json.success) posts = json.data;
  const popJson = await popularRes.json();
  if (popJson.success) popularPosts = popJson.data;
} catch {
  // API not available during build
}

const pageTitle = q ? `${t("home.searchResults", { q })} - ${t("site.name")}` : t("home.title");
const basePath = q ? `/?q=${encodeURIComponent(q)}` : "/";
---

<BlogLayout title={pageTitle}>
  <div class="home-content">
    {q && (
      <div class="search-header">
        <h1>{t("home.searchResults", { q })}</h1>
        <p>{t("home.postsFound", { count: posts.total })} <a href="/">{t("home.clearSearch")}</a></p>
      </div>
    )}
    <section class="posts-list">
      {posts.items.length > 0 ? (
        posts.items.map((post: any) => (
          <PostCard
            title={post.title}
            slug={post.slug}
            excerpt={post.excerpt}
            coverImage={post.coverImage}
            publishedAt={post.publishedAt}
            authorName={post.authorName}
            categoryName={post.categoryName}
            categorySlug={post.categorySlug}
            pinned={post.pinned}
          />
        ))
      ) : (
        <div class="empty-state">
          {q ? (
            <>
              <h2>{t("home.noResults")}</h2>
              <p>{t("home.tryDifferent")} <a href="/">{t("home.browseAll")}</a>.</p>
            </>
          ) : (
            <>
              <h2>{t("home.welcome")}</h2>
              <p>{t("home.noPosts")} <a href="/admin">{t("home.adminPanel")}</a>{t("home.startWriting")}</p>
            </>
          )}
        </div>
      )}
    </section>
    <Pagination currentPage={posts.page} totalPages={posts.totalPages} basePath={basePath} />
    {popularPosts.length > 0 && (
      <aside class="popular-sidebar">
        <h3>{t("home.popularPosts")}</h3>
        <ul>
          {popularPosts.map((p: any) => (
            <li>
              <a href={`/post/${p.slug}`}>{p.title}</a>
              <span class="view-badge">{p.viewCount} {t("post.views", { n: "" }).trim()}</span>
            </li>
          ))}
        </ul>
      </aside>
    )}
  </div>
</BlogLayout>

<style>
  .home-content {
    max-width: var(--max-width);
    margin: 0 auto;
  }
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, 2vw, 2rem);
  }
  .search-header {
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }
  .search-header h1 {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }
  .search-header p {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }
  .empty-state {
    text-align: center;
    padding: 6rem 0;
    color: var(--color-text-secondary);
  }
  .empty-state h2 {
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }
  .popular-sidebar {
    margin-top: 3rem;
    padding: 1.5rem;
    background: var(--color-bg-secondary);
    border-radius: 12px;
    border: 1px solid var(--color-border);
  }
  .popular-sidebar h3 {
    font-size: 1rem;
    margin-bottom: 1rem;
  }
  .popular-sidebar ul {
    list-style: none;
    padding: 0;
  }
  .popular-sidebar li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
    gap: 1rem;
  }
  .popular-sidebar li:last-child {
    border-bottom: none;
  }
  .popular-sidebar a {
    font-size: 0.9rem;
    color: var(--color-text);
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .popular-sidebar a:hover {
    color: var(--color-primary);
  }
  .view-badge {
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    flex-shrink: 0;
  }
</style>
