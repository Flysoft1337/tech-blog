---
interface Props {
  title: string;
  slug: string;
  excerpt?: string;
  coverImage?: string;
  publishedAt?: string;
  authorName?: string;
  categoryName?: string;
  categorySlug?: string;
  pinned?: boolean;
}

const {
  title,
  slug,
  excerpt,
  coverImage,
  publishedAt,
  authorName,
  categoryName,
  categorySlug,
  pinned,
} = Astro.props;

const date = publishedAt
  ? new Date(publishedAt).toLocaleDateString("zh-CN", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "";
---

<article class:list={["post-card", { "has-cover": !!coverImage }]}>
  {coverImage && (
    <a href={`/post/${slug}`} class="post-cover">
      <img src={coverImage} alt={title} loading="lazy" />
    </a>
  )}
  <div class="post-info">
    <div class="post-info-top">
      {pinned && <span class="pin-badge">📌 Pinned</span>}
      {categoryName && (
        <a href={`/category/${categorySlug}`} class="post-category">{categoryName}</a>
      )}
    </div>
    <h2><a href={`/post/${slug}`}>{title}</a></h2>
    {excerpt && <p class="post-excerpt">{excerpt}</p>}
    <div class="post-meta">
      {authorName && <span class="meta-author">{authorName}</span>}
      {date && <time>{date}</time>}
    </div>
  </div>
</article>

<style>
  .post-card {
    padding: 1.5rem;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    margin-bottom: 1rem;
    transition: box-shadow 0.2s, border-color 0.2s;
  }
  .post-card:hover {
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    border-color: #d1d5db;
  }
  .post-card.has-cover {
    display: flex;
    gap: 1.5rem;
  }
  .post-cover {
    flex-shrink: 0;
    width: 220px;
    height: 150px;
    border-radius: 6px;
    overflow: hidden;
  }
  .post-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }
  .post-cover:hover img {
    transform: scale(1.05);
  }
  .post-info {
    flex: 1;
    min-width: 0;
  }
  .post-info-top {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 0.375rem;
  }
  .pin-badge {
    font-size: 0.7rem;
    padding: 0.15rem 0.5rem;
    border-radius: 4px;
    background: #eff6ff;
    color: var(--color-primary);
    font-weight: 500;
  }
  .post-category {
    font-size: 0.8rem;
    color: var(--color-primary);
    font-weight: 500;
  }
  h2 {
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
    line-height: 1.4;
  }
  h2 a {
    color: var(--color-text);
  }
  h2 a:hover {
    color: var(--color-primary);
  }
  .post-excerpt {
    color: var(--color-text-secondary);
    font-size: 0.925rem;
    line-height: 1.6;
    margin-bottom: 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .post-meta {
    display: flex;
    gap: 0.75rem;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
  }
  .meta-author {
    font-weight: 500;
  }
  @media (max-width: 640px) {
    .post-card.has-cover {
      flex-direction: column;
    }
    .post-cover {
      width: 100%;
      height: 200px;
    }
  }
</style>
