---
import { t } from "../../i18n/index";

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filtered.length > 0 && (
  <nav class="toc" id="toc-nav">
    <h3>{t("post.toc")}</h3>
    <ul>
      {filtered.map((heading) => (
        <li class:list={[`depth-${heading.depth}`]}>
          <a href={`#${heading.slug}`} data-toc-link={heading.slug}>{heading.text}</a>
        </li>
      ))}
    </ul>
  </nav>
)}

<script is:inline>
(function(){
  var links = document.querySelectorAll("[data-toc-link]");
  if (!links.length) return;
  var headings = [];
  links.forEach(function(link) {
    var id = link.getAttribute("data-toc-link");
    var el = document.getElementById(id);
    if (el) headings.push({ el: el, link: link });
  });
  function update() {
    var current = null;
    for (var i = 0; i < headings.length; i++) {
      if (headings[i].el.getBoundingClientRect().top <= 100) current = headings[i];
    }
    links.forEach(function(l) { l.classList.remove("active"); });
    if (current) current.link.classList.add("active");
  }
  window.addEventListener("scroll", update, { passive: true });
  update();
})();
</script>

<style>
  .toc {
    position: sticky;
    top: 80px;
    padding: 1rem;
    border-left: 2px solid var(--color-border);
    font-size: 0.85rem;
    max-height: calc(100vh - 100px);
    overflow-y: auto;
  }
  .toc h3 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
    margin-bottom: 0.75rem;
  }
  .toc ul {
    list-style: none;
    padding: 0;
  }
  .toc li {
    margin-bottom: 0.375rem;
  }
  .toc a {
    color: var(--color-text-secondary);
  }
  .toc a:hover {
    color: var(--color-primary);
  }
  :global(.toc a.active) {
    color: var(--color-primary);
    font-weight: 600;
  }
  .depth-3 {
    padding-left: 1rem;
  }
</style>
