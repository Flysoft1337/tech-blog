---
import "../styles/global.css";
import Header from "../components/blog/Header.astro";
import Footer from "../components/blog/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const { title = "Tech Blog", description = "A personal tech blog" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Header />
    <main class="container" style="flex:1; padding-top:2rem; padding-bottom:3rem;">
      <slot />
    </main>
    <Footer />
  </body>
</html>
