---
import "../styles/global.css";
import "../styles/admin.css";

interface Props {
  title?: string;
}

const { title = "Admin" } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: "/admin", label: "Dashboard" },
  { href: "/admin/posts", label: "Posts" },
  { href: "/admin/categories", label: "Categories" },
  { href: "/admin/tags", label: "Tags" },
  { href: "/admin/comments", label: "Comments" },
  { href: "/admin/media", label: "Media" },
  { href: "/admin/users", label: "Users" },
  { href: "/admin/settings", label: "Settings" },
];
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} - Admin</title>
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body>
    <div class="admin-layout">
      <aside class="admin-sidebar">
        <h2><a href="/admin">Tech Blog</a></h2>
        <nav class="admin-nav">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={[{ active: currentPath === item.href || (item.href !== "/admin" && currentPath.startsWith(item.href)) }]}
            >
              {item.label}
            </a>
          ))}
          <a href="/" style="margin-top:2rem; border-top:1px solid rgba(255,255,255,0.1); padding-top:0.75rem;">
            View Site
          </a>
        </nav>
      </aside>
      <main class="admin-main">
        <slot />
      </main>
    </div>
    <script>
      const token = localStorage.getItem("accessToken");
      if (!token && !window.location.pathname.includes("/admin/login")) {
        window.location.href = "/admin/login";
      }
    </script>
  </body>
</html>
